# ── Copy to .env for local dev ─────────────────────────────────────────────
# On Render: set these under Environment → Environment Variables

# Get this from Neon dashboard → Connection Details → psycopg2 driver
# MUST include ?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-random-hex-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ⚠️  THIS IS THE CORS FIX — must match your Vercel URL exactly
FRONTEND_URL=https://devconnect-steel.vercel.app

# Optional extra allowed origins (comma-separated)
EXTRA_ORIGINS=
