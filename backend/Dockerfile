# ── Python 3.11-slim: all binary wheels exist, no Rust/C compilation needed ──
FROM python:3.11.9-slim

# Set working directory
WORKDIR /app

# Install only what's needed for psycopg2-binary (nothing extra)
RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy and install dependencies first (layer cache)
COPY requirements.txt .
RUN pip install --no-cache-dir --prefer-binary -r requirements.txt

# Copy the entire backend source
COPY . .

# Expose the port (Render sets $PORT at runtime)
EXPOSE 8000

# Start command
CMD uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}
